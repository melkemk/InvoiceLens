# Groq API key (free tier, no card needed) — used server-side only.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# --- Optional: point at any OpenAI-compatible provider instead ---
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# AI_API_KEY=            # used if GROQ_API_KEY is unset
#
# e.g. OpenAI:  AI_BASE_URL=https://api.openai.com/v1          AI_MODEL=gpt-4o-mini
# e.g. Gemini:  AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  AI_MODEL=gemini-2.0-flash

# Optional: requests allowed per IP per minute (default: 10)
# RATE_LIMIT_PER_MINUTE=10
